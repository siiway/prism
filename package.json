{
  "name": "prism",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "worker:dev": "wrangler dev",
    "build": "tsc -b && vite build",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "wrangler d1 migrations apply prism-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply prism-db --remote",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.4",
    "@fluentui/react-icons": "^2.0.322",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.95.2",
    "hono": "^4.12.9",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "openpgp": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.13.2",
    "worker-mailer": "^1.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react-i18next-translation-checker": "^2.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.5",
    "vitepress": "^1.6.4",
    "wrangler": "^4.77.0"
  }
}
